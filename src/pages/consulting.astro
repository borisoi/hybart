---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
const testimonials = (await getCollection('testimonials')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---
<Base title="Consulting" accent="var(--c-consulting)" crumb="Consulting" wide>
  <div class="cons-cols">
    <div class="prose cons-text">
      <p>I work with artists seeking collaborators outside the arts, organizations bringing artists into their work, and museums rethinking how they support collaborative practice.</p>
      <p>What I offer depends on what you need: strategy, coaching, curating, program development, facilitation. Sometimes it's helping an artist articulate a vision that doesn't fit existing categories. Sometimes it's helping an institution define what a meaningful collaboration with an artist may look like. Sometimes it's making introductions between people who should be talking.</p>
      <p>My expertise is cross-sector collaboration in the arts: embedding artists in science, technology, higher education, healthcare, community development, government. Twenty years doing this as artist, curator, and administrator; I know where the friction points are and what makes these partnerships work. If you're working on something that doesn't fit existing structures, <a href="/contact">let's talk</a>.</p>
    </div>

    <div class="t-grid">
      {testimonials.map((t) => (
        <a href={`/consulting/${t.id}`}>
          <div class="ph" style={`background-image:url('${t.data.image}')`}></div>
          <span>{t.data.title}<em>{t.data.person}</em></span>
        </a>
      ))}
    </div>
  </div>
</Base>

<style>
  .cons-cols { display: grid; grid-template-columns: 38fr 62fr; gap: 56px; align-items: start; margin-top: 40px; }
  .cons-text { position: sticky; top: 24px; max-width: 58ch; }
  .cons-text p:first-child { margin-top: 0; }
  .t-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 14px; }
  .t-grid a {
    position: relative; display: flex; align-items: flex-end;
    aspect-ratio: 4 / 3; overflow: hidden; border-radius: 22px; text-decoration: none;
  }
  .t-grid .ph { position: absolute; inset: 0; background-size: cover; background-position: center; transition: transform .3s ease; }
  .t-grid a:hover .ph { transform: scale(1.04); }
  .t-grid a::after { content: ''; position: absolute; inset: 0; border-radius: 22px;
    background: linear-gradient(to top, rgba(0,0,0,.6), rgba(0,0,0,0) 50%); }
  .t-grid a:hover::after { background: var(--c-consulting); mix-blend-mode: multiply; opacity: .55; }
  .t-grid span {
    position: relative; z-index: 1; color: #faf9f5;
    font-size: 17px; font-weight: 600; letter-spacing: -0.01em; line-height: 1.25;
    padding: 12px 16px;
  }
  .t-grid em { display: block; font-style: normal; font-weight: 400; font-size: 13.5px; opacity: .85; }
  @media (max-width: 980px) {
    .cons-cols { display: block; }
    .cons-text { position: static; margin-bottom: 36px; }
  }
  @media (max-width: 560px) { .t-grid { grid-template-columns: 1fr; } }
</style>
