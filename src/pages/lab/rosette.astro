---
import '../../styles/global.css';
import CmyMenu from '../../components/CmyMenu.astro';
// Variant A — Rosette: four section photos clipped to circles, clustered tight so
// they overlap like a CMYK registration rosette. A CMY/White ink layer multiplies
// over the photos; where circles cross, the inks combine into darker mixed
// overlap areas. Cyan=Music, Magenta=Art, Yellow=Consulting, White=Blog.
const doors = [
  { href: '/art',        label: 'Art',        img: '/images/responsa-09102.jpg',  c: '#EC008C', x: '-1', y: '-1' },
  { href: '/music',      label: 'Music',      img: '/images/field-no-text.jpg',   c: '#00AEEF', x: '1',  y: '-1' },
  { href: '/consulting', label: 'Consulting', img: '/images/srg0974.jpg',         c: '#FFD400', x: '-1', y: '1'  },
  { href: '/blog',       label: 'Blog',       img: '/images/wafaa-home-tile.jpg', c: '#ffffff', x: '1',  y: '1'  },
];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Hybrid Arts — rosette</title>
  <meta name="robots" content="noindex" />
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
</head>
<body class="d-body">
  <CmyMenu />

  <main class="stage">
    <!-- photo layer -->
    <div class="layer imgs">
      {doors.map((d) => (
        <div class="circle img" style={`--img:url('${d.img}'); --x:${d.x}; --y:${d.y}`}></div>
      ))}
    </div>
    <!-- ink layer: multiplies onto photos; discs multiply among themselves -->
    <div class="layer tints">
      {doors.map((d) => (
        <div class="circle tint" style={`--c:${d.c}; --x:${d.x}; --y:${d.y}`}></div>
      ))}
    </div>
    <!-- click + labels -->
    {doors.map((d) => (
      <a class="circle door" href={d.href} style={`--x:${d.x}; --y:${d.y}`}>
        <span style={`--x:${d.x}; --y:${d.y}`}>{d.label}</span>
      </a>
    ))}
    <div class="wordmark">Hybrid&nbsp;Arts</div>
  </main>

  <div class="variants">
    <a href="/lab/rosette" aria-current="page">rosette</a>
    <a href="/lab/lenses">lenses</a>
    <a href="/lab/orbit">orbit</a>
  </div>

<style>
  .d-body { margin: 0; background: var(--bg); }
  .stage {
    position: fixed; inset: 0; overflow: hidden; isolation: isolate; background: var(--bg);
    --R: 30vmin; --o: 15vmin;
  }
  .layer { position: absolute; inset: 0; }
  .circle {
    position: absolute; left: 50%; top: 50%;
    width: calc(var(--R) * 2); height: calc(var(--R) * 2);
    margin: calc(var(--R) * -1) 0 0 calc(var(--R) * -1);
    border-radius: 50%;
    transform: translate(calc(var(--x) * var(--o)), calc(var(--y) * var(--o)));
  }
  .img  { background: var(--img) center / cover no-repeat; }
  /* ink layer multiplies onto photos; isolate so discs blend among themselves first */
  .tints { mix-blend-mode: multiply; isolation: isolate; }
  .tint { background: var(--c); mix-blend-mode: multiply; opacity: .62; }
  .door { display: block; text-decoration: none; z-index: 3; }
  .door span {
    position: absolute; left: 50%; top: 50%;
    transform: translate(-50%, -50%)
      translate(calc(var(--x) * 16vmin), calc(var(--y) * 16vmin));
    color: var(--bg); font-weight: 700; letter-spacing: -0.03em;
    font-size: clamp(22px, 4.2vmin, 52px); white-space: nowrap;
    text-shadow: 0 1px 16px rgba(20,20,20,.6);
    transition: transform .25s ease;
  }
  .door:hover { box-shadow: 0 0 0 4px var(--bg), 0 0 0 9px rgba(20,20,20,.15); z-index: 8; }
  .door:hover span {
    transform: translate(-50%, -50%)
      translate(calc(var(--x) * 16vmin), calc(var(--y) * 16vmin)) scale(1.07);
  }
  .wordmark {
    position: absolute; left: 50%; top: 50%; transform: translate(-50%, -50%);
    color: var(--bg); opacity: .9; pointer-events: none; z-index: 4;
    font-weight: 700; letter-spacing: .03em; text-transform: uppercase;
    font-size: clamp(13px, 1.8vmin, 20px); text-align: center;
  }
  .variants {
    position: fixed; left: 50%; bottom: 16px; transform: translateX(-50%);
    display: flex; gap: 10px; z-index: 30; font-size: 13px; letter-spacing: .02em;
  }
  .variants a {
    color: var(--ink); text-decoration: none; opacity: .55;
    padding: 4px 10px; border: 1px solid rgba(20,20,20,.18); border-radius: 999px;
    background: rgba(250,249,245,.7);
  }
  .variants a[aria-current] { opacity: 1; border-color: var(--ink); }
  @media (max-width: 700px) {
    .stage { --R: 27vmax; --o: 13vmax; }
    .door span { font-size: clamp(20px, 6vmin, 40px); transform: translate(-50%,-50%) translate(calc(var(--x) * 15vmax), calc(var(--y) * 15vmax)); }
  }
</style>
</body>
</html>
