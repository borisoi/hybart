---
import '../styles/global.css';
const doors = [
  { href: '/art', label: 'Art', img: 'https://images.squarespace-cdn.com/content/v1/66913afa4988280c039abac6/3f4ce52d-c86f-4e79-a67b-3879b97f800f/Responsa%21-09102.jpg?format=2500w', c: 'var(--c-art)' },
  { href: '/music', label: 'Music', img: 'https://images.squarespace-cdn.com/content/v1/66913afa4988280c039abac6/1a94579f-c6ba-4183-8ec4-708c55c7a275/Field2.jpg?format=2500w', c: 'var(--c-music)' },
  { href: '/consulting', label: 'Consulting', img: 'https://images.squarespace-cdn.com/content/v1/66913afa4988280c039abac6/a104b426-76b2-4d33-934c-1caf96a3b340/_SRG0974.jpg?format=2500w', c: 'var(--c-consulting)' },
  { href: '/blog', label: 'Blog', img: 'https://images.squarespace-cdn.com/content/v1/66913afa4988280c039abac6/0651557e-e014-4b0f-a672-bfc3e03e9b79/Screenshot+2025-09-09+at+7.55.29%E2%80%AFAM.jpg?format=2500w', c: 'var(--c-blog)' },
];
const nav = [
  ['Art', '/art'], ['Music', '/music'], ['Consulting', '/consulting'],
  ['About', '/about'], ['FAQ', '/faq'], ['Contact', '/contact'], ['Blog', '/blog'],
];
const accents = ['var(--c-art)', 'var(--c-music)', 'var(--c-consulting)', 'var(--c-art)', 'var(--c-blog)', 'var(--c-consulting)', 'var(--c-blog)'];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Design D — Hybrid Arts</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
</head>
<body class="d-body">
  <button id="menu-open" class="menu-btn" aria-label="Open menu">Menu</button>

  <main class="tiles">
    {doors.map((d) => (
      <a href={d.href} style={`--door:${d.c}`}>
        <div class="ph" style={`background-image:url('${d.img}')`}></div>
        <span>{d.label}</span>
      </a>
    ))}
  </main>

  <div id="overlay" class="overlay" hidden>
    <button id="menu-close" class="menu-btn close" aria-label="Close menu">Close</button>
    <nav>
      {nav.map(([label, href], i) => (
        <a href={href} style={`--door:${accents[i]}`}>{label}</a>
      ))}
    </nav>
  </div>

  <p class="switcher"><a href="/design-a">A</a> · <a href="/design-b">B</a> · <a href="/design-c">C</a> · <strong>D</strong> · <a href="/">current</a></p>

<style>
  .d-body { margin: 0; background: var(--bg); }
  .tiles {
    display: grid; grid-template-columns: 1fr 1fr; gap: 14px;
    height: 100vh; padding: 14px; box-sizing: border-box; max-width: none;
  }
  .tiles a { position: relative; display: flex; align-items: flex-end; overflow: hidden; border-radius: 36px; text-decoration: none; }
  .tiles .ph { position: absolute; inset: 0; background-size: cover; background-position: center; transition: transform .3s ease; }
  .tiles a:hover .ph { transform: scale(1.04); }
  .tiles a::after { content: ''; position: absolute; inset: 0; background: var(--door); opacity: 0; mix-blend-mode: multiply; transition: opacity .25s ease; border-radius: 36px; }
  .tiles a:hover::after { opacity: .5; }
  .tiles span {
    position: relative; z-index: 1; color: #faf9f5;
    font-size: clamp(34px, 5vw, 64px); font-weight: 680; letter-spacing: -0.025em;
    padding: 18px 28px;
  }
  .menu-btn {
    position: fixed; top: 18px; right: 18px; z-index: 20;
    font: inherit; font-size: 16px; font-weight: 600; cursor: pointer;
    background: var(--bg); color: var(--ink); border: none; border-radius: 999px; padding: 10px 22px;
  }
  .menu-btn:hover { background: var(--ink); color: var(--bg); }
  .overlay {
    position: fixed; inset: 0; z-index: 10; background: var(--bg);
    display: flex; align-items: center; justify-content: center;
  }
  .overlay[hidden] { display: none; }
  .overlay nav { display: flex; flex-direction: column; align-items: flex-start; }
  .overlay nav a {
    font-size: clamp(40px, 7vh, 76px); font-weight: 680; letter-spacing: -0.03em; line-height: 1.12;
    text-decoration: none; color: var(--ink); transition: color .12s ease, transform .12s ease;
  }
  .overlay nav a:hover { color: var(--door); transform: translateX(0.12em); }
  .switcher { position: fixed; bottom: 10px; left: 18px; z-index: 20; font-size: 13px; color: var(--muted); background: var(--bg); padding: 4px 10px; border-radius: 999px; }
  @media (max-width: 700px) {
    .tiles { grid-template-columns: 1fr; height: auto; min-height: 100vh; }
    .tiles a { aspect-ratio: 4/3; }
  }
</style>

<script>
  const overlay = document.getElementById('overlay');
  document.getElementById('menu-open').addEventListener('click', () => overlay.removeAttribute('hidden'));
  document.getElementById('menu-close').addEventListener('click', () => overlay.setAttribute('hidden', ''));
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') overlay.setAttribute('hidden', ''); });
</script>
</body>
</html>
