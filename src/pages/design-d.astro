---
import '../styles/global.css';
const doors = [
  { href: '/art', label: 'Art', img: '/images/responsa-09102.jpg', c: 'var(--c-art)' },
  { href: '/music', label: 'Music', img: '/images/field-no-text.jpg', c: 'var(--c-music)' },
  { href: '/consulting', label: 'Consulting', img: '/images/srg0974.jpg', c: 'var(--c-consulting)' },
  { href: '/blog', label: 'Blog', img: '/images/screenshot-2025-09-09-at-7-56-15-am.jpg', c: 'var(--c-blog)' },
];
const nav = [
  ['Art', '/art'], ['Music', '/music'], ['Consulting', '/consulting'],
  ['About', '/about'], ['FAQ', '/faq'], ['Contact', '/contact'], ['Blog', '/blog'],
];
const accents = ['var(--c-art)', 'var(--c-music)', 'var(--c-consulting)', 'var(--c-art)', 'var(--c-blog)', 'var(--c-consulting)', 'var(--c-blog)'];
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>Design D — Hybrid Arts</title>
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
</head>
<body class="d-body">
  <button id="menu-toggle" class="menu-btn" aria-label="Menu" aria-expanded="false">
    <span class="dot" style="background:#00AEEF"><img src="/images/rosette-red.png" alt="" /></span>
    <span class="dot" style="background:#EC008C"><img src="/images/rosette-green.png" alt="" /></span>
    <span class="dot" style="background:#FFD400"><img src="/images/rosette-blue.png" alt="" /></span>
  </button>

  <main class="tiles">
    {doors.map((d) => (
      <a href={d.href} style={`--door:${d.c}`}>
        <div class="ph" style={`background-image:url('${d.img}')`}></div>
        <span>{d.label}</span>
      </a>
    ))}
  </main>

  <div id="overlay" class="overlay" hidden>
    <nav>
      {nav.map(([label, href], i) => (
        <a href={href} style={`--door:${accents[i]}`}>{label}</a>
      ))}
    </nav>
  </div>

  <p class="switcher"><a href="/design-a">A</a> · <a href="/design-b">B</a> · <a href="/design-c">C</a> · <strong>D</strong> · <a href="/">current</a></p>

<style>
  .d-body { margin: 0; background: var(--bg); }
  .tiles {
    display: grid; grid-template-columns: 1fr 1fr; gap: 14px;
    height: 100vh; padding: 14px; box-sizing: border-box; max-width: none;
  }
  .tiles a { position: relative; display: flex; align-items: flex-end; overflow: hidden; border-radius: 36px; text-decoration: none; }
  .tiles .ph { position: absolute; inset: 0; background-size: cover; background-position: center; transition: transform .3s ease; }
  .tiles a:hover .ph { transform: scale(1.04); }
  .tiles a::after { content: ''; position: absolute; inset: 0; background: var(--door); opacity: 0; mix-blend-mode: multiply; transition: opacity .25s ease; border-radius: 36px; }
  .tiles a:hover::after { opacity: .5; }
  .tiles span {
    position: relative; z-index: 1; color: #faf9f5;
    font-size: clamp(34px, 5vw, 64px); font-weight: 680; letter-spacing: -0.025em;
    padding: 18px 28px;
  }
  .menu-btn {
    position: fixed; top: 20px; right: 20px; z-index: 20;
    cursor: pointer; background: none; border: none; padding: 0;
    display: flex; gap: 10px;
  }
  .dot {
    width: 54px; height: 54px; border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
  }
  .dot img { width: 82%; height: auto; transition: transform .6s ease; }
  .menu-btn:hover .dot img { transform: rotate(120deg); }
  .menu-btn[aria-expanded="true"] .dot img { transform: rotate(240deg); }
  .overlay {
    position: fixed; inset: 0; z-index: 10; background: var(--bg);
    display: flex; align-items: center; justify-content: center;
  }
  .overlay[hidden] { display: none; }
  .overlay nav { display: flex; flex-direction: column; align-items: flex-start; }
  .overlay nav a {
    font-size: clamp(40px, 7vh, 76px); font-weight: 680; letter-spacing: -0.03em; line-height: 1.12;
    text-decoration: none; color: var(--ink); transition: color .12s ease, transform .12s ease;
  }
  .overlay nav a:hover { color: var(--door); transform: translateX(0.12em); }
  .switcher { position: fixed; bottom: 10px; left: 18px; z-index: 20; font-size: 13px; color: var(--muted); background: var(--bg); padding: 4px 10px; border-radius: 999px; }
  @media (max-width: 700px) {
    .tiles { grid-template-columns: 1fr; height: auto; min-height: 100vh; }
    .tiles a { aspect-ratio: 4/3; }
  }
</style>

<script>
  const overlay = document.getElementById('overlay');
  const toggle = document.getElementById('menu-toggle');
  function setMenu(open) {
    if (open) overlay.removeAttribute('hidden'); else overlay.setAttribute('hidden', '');
    toggle.setAttribute('aria-expanded', String(open));
  }
  toggle.addEventListener('click', () => setMenu(overlay.hasAttribute('hidden')));
  overlay.addEventListener('click', (e) => { if (e.target === overlay) setMenu(false); });
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') setMenu(false); });
</script>
</body>
</html>
