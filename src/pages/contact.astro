---
import Base from '../layouts/Base.astro';
---
<Base title="Contact" accent="var(--c-consulting)">
  <h1>Contact</h1>
  <div class="prose">
    <p>I never turn down a coffee! Whether you have an idea for a collaboration, insights to share on the Hybrid Arts blog, or just want to explore the possibilities of hybrid arts, I'd love to talk. Your unique perspective could spark something incredible. Reach out and let's see where the conversation leads.</p>
  </div>

  <form class="contact" name="contact" method="POST" data-netlify="true" netlify-honeypot="bot-field">
    <p hidden><label>Don't fill this out: <input name="bot-field" /></label></p>
    <label>Name <input type="text" name="name" required /></label>
    <label>Email <input type="email" name="email" required /></label>
    <label>Message <textarea name="message" rows="6" required></textarea></label>
    <button type="submit">Send</button>
  </form>
</Base>
