---
import Base from '../../layouts/Base.astro';
import { getCollection } from 'astro:content';
const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title="Blog" accent="var(--c-blog)">
  <h1>Blog</h1>
  <p style="color: var(--muted);">Essays, interviews and reviews about all things hybrid arts.</p>

  {posts.map((p) => (
    <article class="entry">
      <p class="meta">{fmt(p.data.date)}</p>
      <h2><a href={`/blog/${p.id}`}>{p.data.title}</a></h2>
      {p.data.excerpt && <p><em>{p.data.excerpt}</em></p>}
    </article>
  ))}
</Base>
