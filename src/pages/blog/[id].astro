---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title={post.data.title} description={post.data.excerpt} accent="var(--c-blog)" crumb="Blog" crumbHref="/blog" wide>
  <article class="post">
    <p class="meta">{fmt(post.data.date)} · Boris Oicherman</p>
    <h1>{post.data.title}</h1>
    <div class="prose">
      <Content />
    </div>
  </article>
  <p style="margin-top: 56px;"><a href="/blog">← All posts</a></p>
</Base>

<style>
  .post .meta { color: var(--muted); font-size: 14px; margin: 48px 0 0; }
  .post h1 { margin-top: 8px; max-width: 26ch; }
  .post :global(.prose img) { border-radius: 22px; margin: 0 0 20px; width: 100%; }
  .post :global(.prose iframe) { border-radius: 22px; width: 100%; }
  .post :global(.prose.cols) { position: relative; }
  .post :global(.prose.cols > :not(.rmedia)) { max-width: min(64ch, 57%); }
  .post :global(.prose.cols > .rmedia) { position: absolute; left: 59%; width: 41%; margin: 0; }
  .post :global(.rmedia) { margin: 18px 0; }
  .post :global(.rmedia p) { max-width: none; margin: 0 0 14px; }
  .post :global(.rmedia iframe) { max-width: none; }
  .post :global(.rmedia p.cap) { margin: -8px 4px 24px; }
  .post :global(.prose .gal) { max-width: none; margin: 0 0 20px; }
  .post :global(.rmedia .gal + p.cap) { margin-top: -2px; }
  .post :global(.rmedia p:not(.cap) img) { max-height: 68vh; width: auto; max-width: 100%; }
  .post :global(p.pull) {
    font-size: clamp(20px, 2.3vw, 25px);
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 68px 0;
    max-width: 36ch;
    color: var(--c-blog);
  }
  .post :global(.prose.cols > p.pull) { max-width: min(36ch, 57%); }
  .post :global(.intro) { border-top: 1px solid var(--rule); padding: 2px 0; }
  .post :global(.intro.intro-last) { border-bottom: 1px solid var(--rule); }
  .post :global(.intro-head) {
    display: block; width: 100%; text-align: left;
    background: none; border: 0; color: inherit; font: inherit;
    cursor: pointer; padding: 14px 0; font-weight: 600; font-size: 19px;
  }
  .post :global(.intro-head::after) { content: ' +'; color: var(--c-blog); }
  .post :global(.intro.open .intro-head::after) { content: ' –'; }
  .post :global(.intro-head:hover) { color: var(--c-blog); }
  .post :global(.intro.intro-last) { margin-bottom: 3.2em; }
  .post :global(p.rosette) { float: left; clear: left; width: 96px; margin: 6px 22px 6px 0; }
  .post :global(p.rosette img) { width: 100%; margin: 0; border-radius: 0; }
  .post :global(.intro-body) {
    overflow: hidden; max-height: 7.8em;
    -webkit-mask-image: linear-gradient(#000 50%, transparent 97%);
    mask-image: linear-gradient(#000 50%, transparent 97%);
  }
  .post :global(.intro.open .intro-body) {
    max-height: none; padding-bottom: 4px;
    -webkit-mask-image: none; mask-image: none;
  }
  .post :global(.intro-body p) { margin-top: 0; }
  .post :global(.intro-close) {
    display: none; background: none; border: 0; font: inherit;
    cursor: pointer; padding: 0 0 16px; color: var(--muted); font-size: 15px;
  }
  .post :global(.intro.open .intro-close) { display: block; }
  .post :global(.intro-close::after) { content: ' –'; color: var(--c-blog); }
  .post :global(.intro-close:hover) { color: var(--c-blog); }
</style>

<script>
  const prose = document.querySelector('.post .prose');
  if (prose) {
    // 1. turn leading "About ..." list blocks into accordions
    //    (closed: title + first lines fading out; open: full text + close link at the bottom)
    const uls = Array.from(prose.children).slice(0, 4).filter((el) => el.tagName === 'UL');
    for (const ul of uls) {
      const lis = Array.from(ul.children).filter((li) => li.querySelector('h1,h2,h3,h4,h5'));
      if (lis.length === 0 || lis.length !== ul.children.length) continue;
      const made = [];
      for (const li of ul.children) {
        const h = li.querySelector('h1,h2,h3,h4,h5');
        const det = document.createElement('div');
        det.className = 'intro';
        const head = document.createElement('button');
        head.type = 'button';
        head.className = 'intro-head';
        head.textContent = h.textContent;
        h.remove();
        const body = document.createElement('div');
        body.className = 'intro-body';
        while (li.firstChild) body.appendChild(li.firstChild);
        const closeBtn = document.createElement('button');
        closeBtn.type = 'button';
        closeBtn.className = 'intro-close';
        closeBtn.textContent = 'Close';
        head.addEventListener('click', () => det.classList.toggle('open'));
        body.addEventListener('click', () => {
          if (!det.classList.contains('open')) det.classList.add('open');
        });
        closeBtn.addEventListener('click', () => {
          det.classList.remove('open');
          if (det.getBoundingClientRect().top < 0) det.scrollIntoView({ block: 'nearest' });
        });
        det.append(head, body, closeBtn);
        made.push(det);
      }
      if (made.length) {
        made[made.length - 1].classList.add('intro-last');
        made.forEach((d) => ul.before(d));
      }
      ul.remove();
    }

    // 1a. rosette chapter markers stay in the text flow as dividers
    for (const el of Array.from(prose.children)) {
      if (
        el.tagName === 'P' &&
        el.children.length === 1 &&
        el.children[0].tagName === 'IMG' &&
        /rosette/i.test(el.children[0].getAttribute('src') || '')
      ) el.classList.add('rosette');
    }

    // 1b. merge consecutive images into an arrow gallery (same widget as art pages)
    const isImgP = (el) => {
      if (el.tagName !== 'P' || el.classList.contains('rosette')) return false;
      let imgs = 0;
      for (const n of el.childNodes) {
        if (n.nodeType === 1 && n.tagName === 'IMG') imgs++;
        else if (n.nodeType === 1 && n.tagName !== 'BR') return false;
        else if (n.nodeType === 3 && n.textContent.trim()) return false;
      }
      return imgs > 0;
    };
    let run = [];
    const flush = () => {
      const imgs = run.flatMap((p) => Array.from(p.querySelectorAll('img')));
      if (imgs.length >= 2) {
        const gal = document.createElement('div');
        gal.className = 'gal';
        gal.innerHTML =
          '<div class="gal-frame"></div><div class="gal-nav">' +
          '<button class="gal-prev" aria-label="Previous image">&lsaquo;</button>' +
          '<span class="gal-count"></span>' +
          '<button class="gal-next" aria-label="Next image">&rsaquo;</button></div>';
        run[0].before(gal);
        const frame = gal.querySelector('.gal-frame');
        imgs.forEach((im) => { im.loading = 'lazy'; frame.appendChild(im); });
        run.forEach((p) => p.remove());
        const count = gal.querySelector('.gal-count');
        let idx = 0;
        const show = (i) => {
          idx = (i + imgs.length) % imgs.length;
          imgs.forEach((im, k) => im.classList.toggle('on', k === idx));
          count.textContent = `${idx + 1} / ${imgs.length}`;
          const im = imgs[idx];
          const fit = () => {
            if (im.naturalWidth) frame.style.aspectRatio = `${im.naturalWidth} / ${im.naturalHeight}`;
          };
          if (im.complete) fit(); else im.addEventListener('load', fit, { once: true });
        };
        gal.querySelector('.gal-prev').addEventListener('click', () => show(idx - 1));
        gal.querySelector('.gal-next').addEventListener('click', () => show(idx + 1));
        show(0);
      }
      run = [];
    };
    for (const el of Array.from(prose.children)) {
      if (isImgP(el)) run.push(el); else flush();
    }
    flush();

    // 2. classify media paragraphs
    const isMediaEl = (el) => {
      if (el.classList && el.classList.contains('gal')) return true;
      if (el.classList && el.classList.contains('rosette')) return false;
      if (el.tagName === 'IFRAME') return true;
      if (el.tagName !== 'P') return false;
      let media = 0;
      for (const n of el.childNodes) {
        if (n.nodeType === 3) { if (n.textContent.trim()) return false; continue; }
        if (n.nodeType !== 1) continue;
        if (n.tagName === 'IMG' || n.tagName === 'IFRAME') media++;
        else if (n.tagName === 'A' && n.children.length === 1 && n.children[0].tagName === 'IMG') media++;
        else if (n.tagName !== 'BR') return false;
      }
      return media > 0;
    };

    // 2b. classify captions (<p><small>…</small></p>) and pull quotes (<p><em>…</em></p>)
    const onlyChild = (el, tag) =>
      el.tagName === 'P' &&
      el.children.length === 1 &&
      el.children[0].tagName === tag &&
      Array.from(el.childNodes).every((n) => n.nodeType !== 3 || !n.textContent.trim());
    const isCaption = (el) => onlyChild(el, 'SMALL');
    for (const el of Array.from(prose.children)) {
      if (onlyChild(el, 'EM')) el.classList.add('pull');
    }

    // 3. marginalia layout: text flows continuously in the left column;
    //    each media group is absolutely positioned in the right margin, anchored
    //    to the start of its passage but sliding down when the previous group
    //    needs the room — so text never gets stretched by tall media.
    const groups = [];
    let curMedia = null;
    let chunkStart = null;
    for (const el of Array.from(prose.children)) {
      if (isMediaEl(el)) {
        if (!curMedia) { curMedia = { els: [], anchor: chunkStart }; groups.push(curMedia); }
        curMedia.els.push(el);
      } else if (isCaption(el) && curMedia) {
        el.classList.add('cap');
        curMedia.els.push(el);
      } else {
        if (curMedia) { curMedia = null; chunkStart = null; }
        if (!chunkStart) chunkStart = el;
      }
    }
    for (const g of groups) {
      const wrap = document.createElement('div');
      wrap.className = 'rmedia';
      g.els[0].before(wrap);
      g.els.forEach((el) => wrap.appendChild(el));
      g.el = wrap;
    }

    const place = () => {
      if (!groups.length) return;
      if (window.matchMedia('(max-width: 860px)').matches) {
        prose.classList.remove('cols');
        groups.forEach((g) => { g.el.style.top = ''; });
        prose.style.minHeight = '';
        return;
      }
      prose.classList.add('cols');
      let prevBottom = 0;
      for (const g of groups) {
        const top = Math.max(g.anchor ? g.anchor.offsetTop : 0, prevBottom);
        g.el.style.top = top + 'px';
        prevBottom = top + g.el.offsetHeight + 36;
      }
      prose.style.minHeight = prevBottom - 36 + 'px';
    };
    let raf = 0;
    const schedule = () => { cancelAnimationFrame(raf); raf = requestAnimationFrame(place); };
    const ro = new ResizeObserver(schedule);
    ro.observe(prose);
    groups.forEach((g) => ro.observe(g.el));
    window.addEventListener('resize', schedule);
    prose.querySelectorAll('img').forEach((im) => {
      if (!im.complete) im.addEventListener('load', schedule, { once: true });
    });
    schedule();

    // 4. lightbox for images and gallery images (same as art pages), rosettes excluded
    const zoomables = Array.from(prose.querySelectorAll('img')).filter(
      (im) => !im.closest('a') && !im.closest('.rosette')
    );
    if (zoomables.length) {
      const box = document.createElement('div');
      box.className = 'lightbox';
      box.hidden = true;
      box.innerHTML =
        '<button class="lb-prev" aria-label="Previous image">&lsaquo;</button>' +
        '<img alt="" />' +
        '<button class="lb-next" aria-label="Next image">&rsaquo;</button>';
      document.body.appendChild(box);
      const boxImg = box.querySelector('img');
      let lbIdx = 0;
      const lbShow = (i) => {
        lbIdx = (i + zoomables.length) % zoomables.length;
        boxImg.src = zoomables[lbIdx].src;
      };
      const close = () => { box.hidden = true; document.body.style.overflow = ''; };
      box.addEventListener('click', close);
      box.querySelector('.lb-prev').addEventListener('click', (e) => { e.stopPropagation(); lbShow(lbIdx - 1); });
      box.querySelector('.lb-next').addEventListener('click', (e) => { e.stopPropagation(); lbShow(lbIdx + 1); });
      document.addEventListener('keydown', (e) => {
        if (box.hidden) return;
        if (e.key === 'Escape') close();
        if (e.key === 'ArrowLeft') lbShow(lbIdx - 1);
        if (e.key === 'ArrowRight') lbShow(lbIdx + 1);
      });
      if (zoomables.length < 2) box.classList.add('lb-single');
      zoomables.forEach((im, i) => {
        im.classList.add('zoomable');
        im.addEventListener('click', () => {
          lbShow(i);
          box.hidden = false;
          document.body.style.overflow = 'hidden';
        });
      });
    }
  }
</script>
