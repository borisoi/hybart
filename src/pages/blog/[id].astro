---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({ params: { id: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
const fmt = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---
<Base title={post.data.title} description={post.data.excerpt} accent="var(--c-blog)" crumb="Blog" crumbHref="/blog" wide>
  <article class="post">
    <p class="meta">{fmt(post.data.date)} · Boris Oicherman</p>
    <h1>{post.data.title}</h1>
    <div class="prose">
      <Content />
    </div>
  </article>
  <p style="margin-top: 56px;"><a href="/blog">← All posts</a></p>
</Base>

<style>
  .post .meta { color: var(--muted); font-size: 14px; margin: 48px 0 0; }
  .post h1 { margin-top: 8px; max-width: 26ch; }
  .post :global(.prose img) { border-radius: 22px; margin: 0 0 20px; width: 100%; }
  .post :global(.prose iframe) { border-radius: 22px; width: 100%; }
  .post :global(.brow) { display: grid; grid-template-columns: 58fr 42fr; gap: 52px; align-items: start; margin-bottom: 8px; }
  .post :global(.brow .rtext) { max-width: 64ch; }
  .post :global(.brow .rtext > :first-child) { margin-top: 0; }
  .post :global(.brow .rmedia) { position: sticky; top: 24px; padding-top: 6px; }
  .post :global(.brow .rmedia p) { max-width: none; margin: 0 0 14px; }
  .post :global(.rmedia p.cap) { margin: -8px 4px 24px; }
  .post :global(.prose .gal) { max-width: none; margin: 0 0 20px; }
  .post :global(.rmedia .gal + p.cap) { margin-top: -2px; }
  .post :global(.rmedia p:not(.cap) img) { max-height: 68vh; width: auto; max-width: 100%; }
  .post :global(p.pull) {
    font-size: clamp(20px, 2.3vw, 25px);
    line-height: 1.3;
    letter-spacing: -0.01em;
    margin: 40px 0;
    max-width: 36ch;
    color: var(--c-blog);
  }
  .post :global(details.intro) { border-top: 1px solid var(--rule); padding: 2px 0; }
  .post :global(details.intro:last-of-type) { border-bottom: 1px solid var(--rule); }
  .post :global(details.intro summary) { cursor: pointer; list-style: none; padding: 14px 0; font-weight: 600; font-size: 17px; }
  .post :global(details.intro summary::-webkit-details-marker) { display: none; }
  .post :global(details.intro summary::after) { content: ' +'; color: var(--c-blog); }
  .post :global(details.intro[open] summary::after) { content: ' –'; }
  .post :global(details.intro summary:hover) { color: var(--c-blog); }
  .post :global(details.intro .intro-body) { padding: 0 0 18px; }
  .post :global(details.intro .intro-body p) { margin-top: 0; }
  @media (max-width: 860px) {
    .post :global(.brow) { display: block; }
    .post :global(.brow .rmedia) { position: static; margin: 18px 0; }
  }
</style>

<script>
  const prose = document.querySelector('.post .prose');
  if (prose) {
    // 1. turn leading "About ..." list blocks into accordions
    const uls = Array.from(prose.children).slice(0, 4).filter((el) => el.tagName === 'UL');
    const intros = [];
    for (const ul of uls) {
      const lis = Array.from(ul.children).filter((li) => li.querySelector('h1,h2,h3,h4,h5'));
      if (lis.length === 0 || lis.length !== ul.children.length) continue;
      for (const li of ul.children) {
        const h = li.querySelector('h1,h2,h3,h4,h5');
        const det = document.createElement('details');
        det.className = 'intro';
        const sum = document.createElement('summary');
        sum.textContent = h.textContent;
        h.remove();
        const body = document.createElement('div');
        body.className = 'intro-body';
        while (li.firstChild) body.appendChild(li.firstChild);
        det.append(sum, body);
        intros.push(det);
      }
      ul.remove();
    }

    // 1b. merge consecutive images into an arrow gallery (same widget as art pages)
    const isImgP = (el) => {
      if (el.tagName !== 'P') return false;
      let imgs = 0;
      for (const n of el.childNodes) {
        if (n.nodeType === 1 && n.tagName === 'IMG') imgs++;
        else if (n.nodeType === 1 && n.tagName !== 'BR') return false;
        else if (n.nodeType === 3 && n.textContent.trim()) return false;
      }
      return imgs > 0;
    };
    let run = [];
    const flush = () => {
      const imgs = run.flatMap((p) => Array.from(p.querySelectorAll('img')));
      if (imgs.length >= 2) {
        const gal = document.createElement('div');
        gal.className = 'gal';
        gal.innerHTML =
          '<div class="gal-frame"></div><div class="gal-nav">' +
          '<button class="gal-prev" aria-label="Previous image">&lsaquo;</button>' +
          '<span class="gal-count"></span>' +
          '<button class="gal-next" aria-label="Next image">&rsaquo;</button></div>';
        run[0].before(gal);
        const frame = gal.querySelector('.gal-frame');
        imgs.forEach((im) => { im.loading = 'lazy'; frame.appendChild(im); });
        run.forEach((p) => p.remove());
        const count = gal.querySelector('.gal-count');
        let idx = 0;
        const show = (i) => {
          idx = (i + imgs.length) % imgs.length;
          imgs.forEach((im, k) => im.classList.toggle('on', k === idx));
          count.textContent = `${idx + 1} / ${imgs.length}`;
          const im = imgs[idx];
          const fit = () => {
            if (im.naturalWidth) frame.style.aspectRatio = `${im.naturalWidth} / ${im.naturalHeight}`;
          };
          if (im.complete) fit(); else im.addEventListener('load', fit, { once: true });
        };
        gal.querySelector('.gal-prev').addEventListener('click', () => show(idx - 1));
        gal.querySelector('.gal-next').addEventListener('click', () => show(idx + 1));
        show(0);
      }
      run = [];
    };
    for (const el of Array.from(prose.children)) {
      if (isImgP(el)) run.push(el); else flush();
    }
    flush();

    // 2. classify media paragraphs
    const isMediaEl = (el) => {
      if (el.classList && el.classList.contains('gal')) return true;
      if (el.tagName === 'IFRAME') return true;
      if (el.tagName !== 'P') return false;
      let media = 0;
      for (const n of el.childNodes) {
        if (n.nodeType === 3) { if (n.textContent.trim()) return false; continue; }
        if (n.nodeType !== 1) continue;
        if (n.tagName === 'IMG' || n.tagName === 'IFRAME') media++;
        else if (n.tagName === 'A' && n.children.length === 1 && n.children[0].tagName === 'IMG') media++;
        else if (n.tagName !== 'BR') return false;
      }
      return media > 0;
    };

    // 2b. classify captions (<p><small>…</small></p>) and pull quotes (<p><em>…</em></p>)
    const onlyChild = (el, tag) =>
      el.tagName === 'P' &&
      el.children.length === 1 &&
      el.children[0].tagName === tag &&
      Array.from(el.childNodes).every((n) => n.nodeType !== 3 || !n.textContent.trim());
    const isCaption = (el) => onlyChild(el, 'SMALL');
    for (const el of Array.from(prose.children)) {
      if (onlyChild(el, 'EM')) el.classList.add('pull');
    }

    // 3. pull the lead image (cover) if it opens the post
    const kids = () => Array.from(prose.children);
    let coverEl = null;
    for (const el of kids().slice(0, 2)) {
      if (isMediaEl(el)) { coverEl = el; break; }
    }
    let coverCap = null;
    if (coverEl) {
      const next = coverEl.nextElementSibling;
      if (next && isCaption(next)) {
        coverCap = next;
        coverCap.classList.add('cap');
        coverCap.remove();
      }
      coverEl.remove();
    }
    const coverGroup = coverEl ? (coverCap ? [coverEl, coverCap] : [coverEl]) : [];

    // 4. build rows: text accumulates left, each media element closes a row on the right
    const rows = [];
    let current = { text: [], media: [] };
    if (intros.length) {
      current.text = intros;
      current.media = coverGroup;
      rows.push(current);
      current = { text: [], media: [] };
    } else {
      current.media.push(...coverGroup);
    }
    let prevWasMedia = !!coverEl;
    for (const el of kids()) {
      if (isMediaEl(el)) {
        current.media.push(el);
        prevWasMedia = true;
      } else if (isCaption(el) && prevWasMedia) {
        // caption stays under its image
        el.classList.add('cap');
        if (current.media.length) current.media.push(el);
        else if (rows.length) rows[rows.length - 1].media.push(el);
        else current.media.push(el);
      } else {
        if (current.media.length && current.text.length) {
          rows.push(current);
          current = { text: [], media: [] };
        }
        current.text.push(el);
        prevWasMedia = false;
      }
    }
    if (current.text.length || current.media.length) rows.push(current);

    for (const r of rows) {
      const row = document.createElement('div');
      row.className = 'brow';
      const rt = document.createElement('div'); rt.className = 'rtext';
      const rm = document.createElement('div'); rm.className = 'rmedia';
      r.text.forEach((el) => rt.appendChild(el));
      r.media.forEach((el) => rm.appendChild(el));
      row.append(rt, rm);
      prose.appendChild(row);
    }
  }
</script>
