---
import Base from '../layouts/Base.astro';
import { getCollection } from 'astro:content';
const projects = (await getCollection('music')).sort((a, b) => a.data.order - b.data.order);

const isYearTag = (t: string) => /^(19|20)\d\d( ?[-–] ?((19|20)?\d\d)?)?$/.test(t.trim());
const info = projects.map((p) => {
  const yt = p.data.tags.find(isYearTag);
  const year = yt ? yt.slice(0, 4) : String(p.data.date.getFullYear());
  let yearLabel = yt ? yt.trim().replace(/ ?[-–] ?/, '–') : year;
  const range = yearLabel.match(/^(\d{4})–(\d{4})$/);
  if (range && range[1].slice(0, 2) === range[2].slice(0, 2)) yearLabel = `${range[1]}–${range[2].slice(2)}`;
  return { p, yearLabel };
});
const extras = [
  { href: '/art/the-world-in-dub', title: 'The World In Dub', yearLabel: '2024–25', cover: '/images/art/radio-headshot.jpeg' },
];
---
<Base title="Music" description="Music projects by Boris Oicherman / Against Interpretation" accent="var(--c-music)" crumb="Music" wide>
  <div class="music-grid">
    {info.map(({ p, yearLabel }) => (
      <a href={`/music/${p.id}`}>
        <div class="ph" style={`background-image:url('${p.data.cover}')`}></div>
        <span>{p.data.shortTitle ?? p.data.title} ({yearLabel})</span>
      </a>
    ))}
    {extras.map((e) => (
      <a href={e.href}>
        <div class="ph" style={`background-image:url('${e.cover}')`}></div>
        <span>{e.title} ({e.yearLabel})</span>
      </a>
    ))}
  </div>
</Base>

<style>
  .music-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 14px; margin-top: 28px; }
  .music-grid a {
    position: relative; display: flex; align-items: flex-end;
    aspect-ratio: 4 / 3; overflow: hidden; border-radius: 22px; text-decoration: none;
  }
  .music-grid .ph { position: absolute; inset: 0; background-size: cover; background-position: center; transition: transform .3s ease; }
  .music-grid a:hover .ph { transform: scale(1.04); }
  .music-grid a::after { content: ''; position: absolute; inset: 0; border-radius: 22px;
    background: linear-gradient(to top, rgba(0,0,0,.55), rgba(0,0,0,0) 45%); }
  .music-grid a:hover::after { background: var(--c-music); mix-blend-mode: multiply; opacity: .55; }
  .music-grid span {
    position: relative; z-index: 1; color: #faf9f5;
    font-size: 17px; font-weight: 600; letter-spacing: -0.01em; line-height: 1.25;
    padding: 12px 16px;
  }
  @media (max-width: 1200px) { .music-grid { grid-template-columns: repeat(3, 1fr); } }
  @media (max-width: 860px) { .music-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 540px) { .music-grid { grid-template-columns: 1fr; } }
</style>
