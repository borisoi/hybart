---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('art');
  return projects.map((p) => ({ params: { id: p.id }, props: { p } }));
}

const { p } = Astro.props;
const { Content } = await render(p);
const year = p.data.tags.find((t) => /^(19|20)\d\d/.test(t));
---
<Base title={p.data.title} accent="var(--c-art)">
  <article class="art-project">
    <p class="meta">
      {year && <span>{year}</span>}
      {p.data.tags.filter((t) => t !== year).map((t) => <span>{t}</span>)}
    </p>
    <h1>{p.data.title}</h1>
    <div class="prose">
      <Content />
    </div>
  </article>
  <p style="margin-top: 56px;"><a href="/art">← All projects</a></p>
</Base>

<style>
  .art-project .meta { margin: 48px 0 0; display: flex; gap: 14px; flex-wrap: wrap; }
  .art-project .meta span { font-size: 14px; color: var(--muted); }
  .art-project h1 { margin-top: 8px; }
  .art-project :global(.prose img) { border-radius: 22px; margin: 28px 0; }
  .art-project :global(.prose iframe) { width: 100%; max-width: 68ch; aspect-ratio: 16 / 9; height: auto; border-radius: 22px; margin: 28px 0; display: block; }
  .art-project :global(.art-cols) { display: grid; grid-template-columns: 1.05fr 0.95fr; gap: 44px; align-items: start; }
  .art-project :global(.art-cols .col-media) { position: sticky; top: 24px; }
  .art-project :global(.art-cols .col-media .gal),
  .art-project :global(.art-cols .col-media iframe),
  .art-project :global(.art-cols .col-media img) { max-width: none; width: 100%; }
  .art-project :global(.art-cols .col-media > :first-child) { margin-top: 28px; }
  .art-project :global(.art-cols .col-text) { max-width: 62ch; }
  @media (max-width: 860px) {
    .art-project :global(.art-cols) { display: block; }
    .art-project :global(.art-cols .col-media) { position: static; }
  }
</style>

<script>
  const prose = document.querySelector('.art-project .prose');
  if (prose) {
    const isImgP = (el) => {
      if (el.tagName !== 'P') return false;
      let imgs = 0;
      for (const n of el.childNodes) {
        if (n.nodeType === 1 && n.tagName === 'IMG') imgs++;
        else if (n.nodeType === 1 && n.tagName !== 'BR') return false;
        else if (n.nodeType === 3 && n.textContent.trim()) return false;
      }
      return imgs > 0;
    };
    let run = [];
    const flush = () => {
      const imgs = run.flatMap((p) => Array.from(p.querySelectorAll('img')));
      if (imgs.length >= 2) {
        const gal = document.createElement('div');
        gal.className = 'gal';
        gal.innerHTML =
          '<div class="gal-frame"></div><div class="gal-nav">' +
          '<button class="gal-prev" aria-label="Previous image">&lsaquo;</button>' +
          '<span class="gal-count"></span>' +
          '<button class="gal-next" aria-label="Next image">&rsaquo;</button></div>';
        run[0].before(gal);
        const frame = gal.querySelector('.gal-frame');
        imgs.forEach((im) => { im.loading = 'lazy'; frame.appendChild(im); });
        run.forEach((p) => p.remove());
        const count = gal.querySelector('.gal-count');
        let idx = 0;
        const show = (i) => {
          idx = (i + imgs.length) % imgs.length;
          imgs.forEach((im, k) => im.classList.toggle('on', k === idx));
          count.textContent = `${idx + 1} / ${imgs.length}`;
          const im = imgs[idx];
          const fit = () => {
            if (im.naturalWidth) frame.style.aspectRatio = `${im.naturalWidth} / ${im.naturalHeight}`;
          };
          if (im.complete) fit(); else im.addEventListener('load', fit, { once: true });
        };
        gal.querySelector('.gal-prev').addEventListener('click', () => show(idx - 1));
        gal.querySelector('.gal-next').addEventListener('click', () => show(idx + 1));
        show(0);
      }
      run = [];
    };
    for (const el of Array.from(prose.children)) {
      if (isImgP(el)) run.push(el); else flush();
    }
    flush();

    // split into media (left) and text (right) columns
    const isMediaEl = (el) => {
      if (el.classList && el.classList.contains('gal')) return true;
      if (el.tagName === 'IFRAME') return true;
      if (el.tagName !== 'P') return false;
      let media = 0;
      for (const n of el.childNodes) {
        if (n.nodeType === 3) { if (n.textContent.trim()) return false; continue; }
        if (n.nodeType !== 1) continue;
        if (n.tagName === 'IMG' || n.tagName === 'IFRAME') media++;
        else if (n.tagName === 'A' && n.children.length === 1 && n.children[0].tagName === 'IMG') media++;
        else if (n.tagName !== 'BR') return false;
      }
      return media > 0;
    };
    const kids = Array.from(prose.children);
    const mediaEls = kids.filter(isMediaEl);
    if (mediaEls.length > 0 && mediaEls.length < kids.length) {
      const cols = document.createElement('div');
      cols.className = 'art-cols';
      const media = document.createElement('div'); media.className = 'col-media';
      const text = document.createElement('div'); text.className = 'col-text';
      for (const el of kids) (isMediaEl(el) ? media : text).appendChild(el);
      cols.append(media, text);
      prose.appendChild(cols);
    }
  }
</script>
