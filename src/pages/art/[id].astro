---
import Base from '../../layouts/Base.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const projects = await getCollection('art');
  return projects.map((p) => ({ params: { id: p.id }, props: { p } }));
}

const { p } = Astro.props;
const { Content } = await render(p);
const year = p.data.tags.find((t) => /^(19|20)\d\d/.test(t));
const singleColumn = p.id === 'interview-with-robert-irwin';
const isGanzfeld = p.id === 'ganzfeld-dot-art';
---
<Base title={p.data.title} accent="var(--c-art)" crumb="Art" crumbHref="/art" wide>
  <article class="art-project" data-single={singleColumn ? '1' : undefined}>
    <p class="meta">
      {year && <span>{year}</span>}
      {p.data.tags.filter((t) => t !== year).map((t) => <span>{t}</span>)}
    </p>
    <h1>{p.data.title}</h1>
    <div class="prose">
      <Content />
    </div>
  </article>
  <p style="margin-top: 56px;"><a href="/art">← All projects</a></p>
  {isGanzfeld && (
    <div id="ganzfeld-overlay" hidden>
      <button id="ganzfeld-close" type="button" aria-label="Exit (Esc)">×</button>
    </div>
  )}
</Base>

<style>
  .art-project.narrow { max-width: 72ch; margin-inline: auto; }
  .art-project.narrow :global(.prose > p:first-child img),
  .art-project.narrow :global(.prose > p:first-child) { max-width: none; }
  .art-project.narrow :global(.prose img) { width: 100%; margin: 28px auto; }
  .art-project .meta { margin: 48px 0 0; display: flex; gap: 14px; flex-wrap: wrap; }
  .art-project .meta span { font-size: 14px; color: var(--muted); }
  .art-project h1 { margin-top: 8px; }
  .art-project :global(.prose img) { border-radius: 22px; margin: 28px 0; }
  .art-project :global(.prose iframe) { width: 100%; max-width: 68ch; aspect-ratio: 16 / 9; height: auto; border-radius: 22px; margin: 28px 0; display: block; }
  .art-project :global(.prose iframe[src*="bandcamp"]) { aspect-ratio: auto; height: 470px; max-width: 420px; }
  .art-project :global(.art-cols) { display: grid; grid-template-columns: 65fr 35fr; gap: 44px; align-items: start; margin-top: 28px; }
  .art-project :global(.art-cols.solo .col-media) { position: sticky; top: 24px; }
  .art-project :global(.art-cols .col-media .gal),
  .art-project :global(.art-cols .col-media p),
  .art-project :global(.art-cols .col-media iframe),
  .art-project :global(.art-cols .col-media img) { max-width: none; width: 100%; }
  /* gallery images size to their content so portraits stay centered */
  .art-project :global(.art-cols .col-media .gal-frame img) { width: auto; max-width: 100%; }
  /* line up the tops of the media and text columns */
  .art-project :global(.art-cols .col-media > :first-child),
  .art-project :global(.art-cols .col-text > :first-child) { margin-top: 0; }
  .art-project :global(.art-cols .col-media > :first-child img) { margin-top: 0; }
  .art-project :global(.art-cols .col-text) { max-width: 62ch; }
  #ganzfeld-overlay { position: fixed; inset: 0; z-index: 9999; background: #000; }
  #ganzfeld-overlay[hidden] { display: none; }
  #ganzfeld-close {
    position: fixed; top: 16px; right: 22px; z-index: 10000;
    background: none; border: 0; padding: 0; line-height: 1;
    font-size: 34px; color: rgba(255, 255, 255, 0.55); cursor: pointer;
    transition: color 0.2s;
  }
  #ganzfeld-close:hover { color: rgba(255, 255, 255, 0.9); }
  @media (max-width: 860px) {
    .art-project :global(.art-cols) { display: block; }
    .art-project :global(.art-cols .col-media) { position: static; }
  }
</style>

<script>
  const prose = document.querySelector('.art-project .prose');
  if (prose) {
    const isImgP = (el) => {
      if (el.tagName !== 'P') return false;
      let imgs = 0;
      for (const n of el.childNodes) {
        if (n.nodeType === 1 && n.tagName === 'IMG') imgs++;
        else if (n.nodeType === 1 && n.tagName !== 'BR') return false;
        else if (n.nodeType === 3 && n.textContent.trim()) return false;
      }
      return imgs > 0;
    };
    let run = [];
    const flush = () => {
      const imgs = run.flatMap((p) => Array.from(p.querySelectorAll('img')));
      if (imgs.length >= 2) {
        const gal = document.createElement('div');
        gal.className = 'gal';
        gal.innerHTML =
          '<div class="gal-frame"></div><div class="gal-nav">' +
          '<button class="gal-prev" aria-label="Previous image">&lsaquo;</button>' +
          '<span class="gal-count"></span>' +
          '<button class="gal-next" aria-label="Next image">&rsaquo;</button></div>';
        run[0].before(gal);
        const frame = gal.querySelector('.gal-frame');
        imgs.forEach((im) => { im.loading = 'lazy'; frame.appendChild(im); });
        run.forEach((p) => p.remove());
        const count = gal.querySelector('.gal-count');
        let idx = 0;
        const show = (i) => {
          idx = (i + imgs.length) % imgs.length;
          imgs.forEach((im, k) => im.classList.toggle('on', k === idx));
          count.textContent = `${idx + 1} / ${imgs.length}`;
        };
        gal.querySelector('.gal-prev').addEventListener('click', () => show(idx - 1));
        gal.querySelector('.gal-next').addEventListener('click', () => show(idx + 1));
        show(0);
      }
      run = [];
    };
    for (const el of Array.from(prose.children)) {
      if (isImgP(el)) run.push(el); else flush();
    }
    flush();

    // split into media (left) and text (right) columns
    const isMediaEl = (el) => {
      if (el.classList && el.classList.contains('gal')) return true;
      if (el.tagName === 'IFRAME') return true;
      if (el.tagName !== 'P') return false;
      let media = 0;
      for (const n of el.childNodes) {
        if (n.nodeType === 3) { if (n.textContent.trim()) return false; continue; }
        if (n.nodeType !== 1) continue;
        if (n.tagName === 'IMG' || n.tagName === 'IFRAME') media++;
        else if (n.tagName === 'A' && n.children.length === 1 && n.children[0].tagName === 'IMG') media++;
        else if (n.tagName !== 'BR') return false;
      }
      return media > 0;
    };
    const kids = Array.from(prose.children);
    const mediaEls = kids.filter(isMediaEl);
    const single = document.querySelector('.art-project')?.dataset.single === '1';

    // exactly one image and nothing else: centered essay, image on top (like blog essays)
    const soloImg =
      mediaEls.length === 1 &&
      !mediaEls[0].classList.contains('gal') &&
      mediaEls[0].tagName !== 'IFRAME' &&
      !mediaEls[0].querySelector('iframe');
    if (soloImg || mediaEls.length === 0 || single) {
      document.querySelector('.art-project')?.classList.add('narrow');
      if (soloImg) prose.prepend(mediaEls[0]);
    } else if (mediaEls.length > 0) {
      const cols = document.createElement('div');
      cols.className = 'art-cols';
      const media = document.createElement('div'); media.className = 'col-media';
      const text = document.createElement('div'); text.className = 'col-text';
      for (const el of kids) (isMediaEl(el) ? media : text).appendChild(el);
      cols.append(media, text);
      prose.appendChild(cols);
      const updatePin = () =>
        cols.classList.toggle('solo', media.offsetHeight < window.innerHeight - 90);
      new ResizeObserver(updatePin).observe(media);
      window.addEventListener('resize', updatePin);
      updatePin();
    }

    // lightbox for images (not linked images, not videos)
    const zoomables = Array.from(prose.querySelectorAll('img')).filter((im) => !im.closest('a'));
    const box = document.createElement('div');
    box.className = 'lightbox';
    box.hidden = true;
    box.innerHTML =
      '<button class="lb-prev" aria-label="Previous image">&lsaquo;</button>' +
      '<img alt="" />' +
      '<button class="lb-next" aria-label="Next image">&rsaquo;</button>';
    document.body.appendChild(box);
    const boxImg = box.querySelector('img');
    let lbIdx = 0;
    const lbShow = (i) => {
      lbIdx = (i + zoomables.length) % zoomables.length;
      boxImg.src = zoomables[lbIdx].src;
    };
    const close = () => { box.hidden = true; document.body.style.overflow = ''; };
    box.addEventListener('click', close);
    box.querySelector('.lb-prev').addEventListener('click', (e) => { e.stopPropagation(); lbShow(lbIdx - 1); });
    box.querySelector('.lb-next').addEventListener('click', (e) => { e.stopPropagation(); lbShow(lbIdx + 1); });
    document.addEventListener('keydown', (e) => {
      if (box.hidden) return;
      if (e.key === 'Escape') close();
      if (e.key === 'ArrowLeft') lbShow(lbIdx - 1);
      if (e.key === 'ArrowRight') lbShow(lbIdx + 1);
    });
    if (zoomables.length < 2) box.classList.add('lb-single');
    zoomables.forEach((im, i) => {
      im.classList.add('zoomable');
      im.addEventListener('click', () => {
        lbShow(i);
        box.hidden = false;
        document.body.style.overflow = 'hidden';
      });
    });
  }
</script>

<script>
  // ganzfeld.art simulation — original by Boris Oicherman, 2020.
  // Slowly cycles a fullscreen overlay through saturated hues.
  const overlay = document.getElementById('ganzfeld-overlay');
  if (overlay) {
    const cycleDuration = 40; // seconds per cycle
    const fps = 25;
    const interval = 1000 / fps;
    const startH = 315, S = 100, L = 50, arc = 45;

    const hsl2rgb = (h, s, l) => {
      s /= 100; l /= 100;
      const c = (1 - Math.abs(2 * l - 1)) * s;
      const x = c * (1 - Math.abs(((h / 60) % 2) - 1));
      const m = l - c / 2;
      let r = 0, g = 0, b = 0;
      if (h < 60) { r = c; g = x; }
      else if (h < 120) { r = x; g = c; }
      else if (h < 180) { g = c; b = x; }
      else if (h < 240) { g = x; b = c; }
      else if (h < 300) { r = x; b = c; }
      else { r = c; b = x; }
      return [
        Math.round((r + m) * 255),
        Math.round((g + m) * 255),
        Math.round((b + m) * 255),
      ];
    };

    // Precompute the hue arc, then mirror it so colour returns to start (cycle).
    const size = cycleDuration * fps;
    const step = arc / size;
    let frames = [];
    for (let i = 0; i < size; i++) frames.push(hsl2rgb((startH + i * step) % 360, S, L));
    frames = frames.concat(frames.slice().reverse());

    let idx = 0;
    let timer = null;
    const paint = () => {
      const [r, g, b] = frames[idx];
      overlay.style.backgroundColor = `rgb(${r},${g},${b})`;
      idx = (idx + 1) % frames.length;
    };
    const open = () => {
      idx = 0;
      overlay.hidden = false;
      document.body.style.overflow = 'hidden';
      paint();
      timer = setInterval(paint, interval);
    };
    const close = () => {
      if (timer) { clearInterval(timer); timer = null; }
      overlay.hidden = true;
      document.body.style.overflow = '';
    };

    document.querySelectorAll('a[href$="#ganzfeld"]').forEach((a) =>
      a.addEventListener('click', (e) => { e.preventDefault(); open(); })
    );
    document.getElementById('ganzfeld-close')?.addEventListener('click', close);
    document.addEventListener('keydown', (e) => {
      if (!overlay.hidden && e.key === 'Escape') close();
    });
  }
</script>
